# --- ML Service (Bridge Pattern) ---
# The URL of the dedicated Paddy Detection ML service.
# In Docker Compose, this is the internal container name.
ML_SERVICE_URL=http://ml-service:8000

# --- MLflow ---
MLFLOW_TRACKING_URI=sqlite:///mlruns.db

# --- Debug ---
DEBUG=false
