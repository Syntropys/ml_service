# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Supabase ---
SUPABASE_URL=https://mawewomqcdnsqnxmkjlq.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
