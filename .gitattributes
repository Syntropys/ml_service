# Set default behavior
* text=auto eol=lf

# Explicitly declare text files to always use LF (Linux/Docker compatibility)
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.env.example text eol=lf

# Declare binary files to PREVENT corruption during git pull/push
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.keras binary
*.h5 binary
*.tflite binary
*.pkl binary
*.db binary
*.sqlite3 binary